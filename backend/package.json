{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\" drizzle.config.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\" \"*.{json,md,yml}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/prepare.ts && drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "worker": "tsx watch src/workers/index.ts",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.12",
    "drizzle-orm": "^0.36.4",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "openai": "^4.68.1",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.8.7",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.12",
    "drizzle-kit": "^0.27.2",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "ws": "^8.18.0"
  }
}
